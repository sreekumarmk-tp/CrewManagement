digraph ImplDedup {
  rankdir=LR;
  graph [fontname="Helvetica", bgcolor="white", nodesep=0.40, ranksep=0.80, pad=0.35, labelloc=t,
         label="Dedup — three complementary layers (at-least-once → exactly-once)",
         fontsize=14, fontcolor="#0F172A"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, penwidth=1.5,
         margin="0.18,0.11", color="#475569", fillcolor="#E2E8F0", fontcolor="#0F172A"];
  edge  [fontname="Helvetica", fontsize=9, color="#64748B", penwidth=1.3, arrowsize=0.8];

  src [label="re-delivered\nsource event", fillcolor="#DBEAFE", color="#2563EB"];

  l1 [label="Layer 1 — connector-local\nSlack event_id seen-set\nERP watermark cursor\nconnectors/*", fillcolor="#DCFCE7", color="#16A34A"];
  l2 [label="Layer 2 — canonical identity\nSignalEvent.dedup_id\ncore/signal.py", fillcolor="#DCFCE7", color="#16A34A"];
  l3 [label="Layer 3 — bus central dedup\nInMemoryBus LRU window\ncore/bus.py", fillcolor="#DCFCE7", color="#16A34A"];

  sink [label="L2 sink\nexactly-once", fillcolor="#EDE9FE", color="#7C3AED"];
  helper [label="dedup_key()\nraw-payload helper\ncore/dedup.py", shape=note, fillcolor="#F1F5F9", color="#94A3B8"];

  src -> l1 -> l2 -> l3 -> sink;
  l2 -> helper [style=dotted, dir=none, color="#94A3B8"];
}
