digraph ImplBus {
  rankdir=LR;
  graph [fontname="Helvetica", bgcolor="white", nodesep=0.40, ranksep=0.70, pad=0.35, labelloc=t,
         label="InMemoryBus — publish(): dedup · fan-out · replay  (core/bus.py)",
         fontsize=14, fontcolor="#0F172A"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, penwidth=1.5,
         margin="0.18,0.11", color="#475569", fillcolor="#E2E8F0", fontcolor="#0F172A"];
  edge  [fontname="Helvetica", fontsize=9, color="#64748B", penwidth=1.3, arrowsize=0.8];

  pub   [label="publish(event)", fillcolor="#DBEAFE", color="#2563EB"];
  seen  [label="dedup_id in\nLRU window?", shape=diamond, fillcolor="#FEF3C7", color="#D97706", margin="0.05,0.05"];
  drop  [label="duplicate_count++\nDUP-DROP log", fillcolor="#FEE2E2", color="#DC2626"];
  rec   [label="record\nhistory ring + counters", fillcolor="#E2E8F0", color="#475569"];
  fan   [label="fan out to subscribers\n(await async)", fillcolor="#DCFCE7", color="#16A34A"];

  l2    [label="L2 sink\nl2/store.py", fillcolor="#EDE9FE", color="#7C3AED"];
  iso   [label="subscriber raises →\nSUBSCRIBER-FAIL (isolated)", shape=note, fillcolor="#FEE2E2", color="#DC2626"];
  rep   [label="replay()\nbring late subscriber current", shape=note, fillcolor="#F1F5F9", color="#94A3B8"];

  pub -> seen;
  seen -> drop [label="yes", fontcolor="#DC2626"];
  seen -> rec  [label="no", fontcolor="#16A34A"];
  rec -> fan -> l2;
  fan -> iso [style=dashed, color="#DC2626"];
  rec -> rep [style=dotted, color="#94A3B8", arrowhead=none];
}
