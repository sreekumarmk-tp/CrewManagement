digraph PushFlow {
  rankdir=TB;
  graph [fontname="Helvetica", bgcolor="white", nodesep=0.35, ranksep=0.55, pad=0.35, labelloc=t,
         label="End-to-End Data Flow — Push Connectors (Slack / Gmail)", fontsize=15, fontcolor="#0F172A"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11, penwidth=1.5,
         margin="0.20,0.11", color="#475569", fillcolor="#E2E8F0", fontcolor="#0F172A"];
  edge  [fontname="Helvetica", fontsize=9, color="#64748B", penwidth=1.3, arrowsize=0.8];

  src    [label="Source action  (message · email · reaction)", fillcolor="#DBEAFE", color="#2563EB"];
  push   [label="HTTPS push → /endpoint", fillcolor="#DBEAFE", color="#2563EB"];
  verify [label="verify()  ·  HMAC / OIDC JWT  ·  replay window"];
  ingest [label="ingest() → RawEvent[]   (dedup on native id)"];
  norm   [label="Normalizer → SignalEvent (DELTA, lineage, checksum)"];
  bus    [label="Event Bus — XADD (Redis Streams)", fillcolor="#FEF3C7", color="#D97706"];
  sink   [label="L2 Sink — idempotent upsert", fillcolor="#DCFCE7", color="#16A34A"];

  orgmap  [label="OrgMap edges", fillcolor="#EDE9FE", color="#7C3AED"];
  signoff [label="SignOffEvent  (if l2Intent)", fillcolor="#EDE9FE", color="#7C3AED"];
  commit  [label="commit() checkpoint  +  emit sinkAt", shape=note, fillcolor="#F1F5F9", color="#94A3B8"];
  obs     [label="SSE /stream  +  /metrics latency gauge", style="rounded,filled,dashed",
           fillcolor="#F1F5F9", color="#94A3B8", fontsize=10];

  src -> push -> verify -> ingest -> norm -> bus -> sink;
  sink -> orgmap;
  sink -> signoff;
  sink -> commit -> obs;
  { rank=same; orgmap; signoff; }
}
