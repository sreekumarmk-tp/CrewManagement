# L1 SignalFabric — environment (all optional; dev-safe defaults baked in)

# Tenant stamped on every SignalEvent
L1_TENANT_ID=maritime-acme

# --- Slack ---
# Set the app signing secret to enforce HMAC verification. When empty AND
# SLACK_DEV_ALLOW_UNVERIFIED=1, unsigned requests are accepted (local/demo).
SLACK_SIGNING_SECRET=
SLACK_DEV_ALLOW_UNVERIFIED=1
SLACK_REPLAY_WINDOW_SEC=300
SLACK_TOKEN=xoxb-...                  # bot token for the Web-API backfill CLI

# Gmail — Pub/Sub push (metadata only)
# Self-refreshing per-user OAuth (recommended): the connector mints fresh access
# tokens from this trio, so a 7-day watch keeps working past the ~1h token life.
# Mint the refresh token once with:  python -m connectors.gmail.cli authorize
GMAIL_CLIENT_ID=...apps.googleusercontent.com
GMAIL_CLIENT_SECRET=...
GMAIL_REFRESH_TOKEN=1//...
GMAIL_PUBSUB_TOKEN=...                # shared-secret echoed on ?token= (push auth)
GMAIL_PUBSUB_TOPIC=projects/<project-id>/topics/gmail-signals   # default for `watch`
GMAIL_PUSH_ENDPOINT=https://<public-host>/gmail/push?token=<shared-secret>
GMAIL_WATERMARK_PATH=./data/gmail.wm.json             # persist the historyId so pushes resume across restarts ("" => in-memory)

# Outlook + SharePoint — Microsoft Graph (one app-only app, two sources)
# Shared client-credentials (app-only) grant:
MS_TENANT_ID=...
MS_CLIENT_ID=...
MS_CLIENT_SECRET=...
# Outlook — unread poll + mark-read (app-only has no /me, so a mailbox is required)
OUTLOOK_MAILBOX_UPN=mailbox@contoso.com
OUTLOOK_MARK_AS_READ=1                # 0 = leave messages unread after emitting
# SharePoint — folder listing under one site's default document library
SHAREPOINT_HOSTNAME=contoso.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/SiteName
SHAREPOINT_FOLDER_PATH=Shared Documents/your-folder   # comma/newline-separated for several
# Hands-off push — Graph change subscriptions (created via the `subscribe` CLIs).
# Public HTTPS base Graph pushes to (e.g. an ngrok tunnel); the CLIs append
# /outlook/webhook and /sharepoint/webhook. Server must be reachable here when you
# run `subscribe` — Graph validates the URL synchronously.
MS_WEBHOOK_BASE_URL=https://<public-host>
OUTLOOK_CLIENT_STATE=...              # secret echoed in + verified on each notification
SHAREPOINT_CLIENT_STATE=...

# Notion
NOTION_TOKEN=ntn_...                  # internal integration token

# Database — generic SQL CDC/outbox; blank => in-memory mimic (demo)
DATABASE_URL=postgresql+psycopg2://user:pass@host/db   # pip install -e ".[postgres]"
DATABASE_OUTBOX_TABLE=signal_outbox
DATABASE_WATERMARK_PATH=./data/db.wm.json             # persist the cursor across restarts

# --- ERP ---
# Path to persist the outbox watermark across restarts ("" => in-memory only)
ERP_WATERMARK_PATH=

# --- server ---
HOST=0.0.0.0
PORT=8001
