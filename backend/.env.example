ANTHROPIC_API_KEY=your_anthropic_api_key_here
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/maritime_crew
REDIS_URL=redis://localhost:6379
# Context graph backend: fallback (Python-built subgraph, default) or age (Apache AGE in Postgres)
GRAPH_BACKEND=fallback
# Structural-embedding similarity (L4 #3): fallback (Python cosine, default) or pgvector (needs pgvector image)
VECTOR_BACKEND=fallback
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
