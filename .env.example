# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional (for Langfuse observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Auto-configured by Docker Compose
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/maritime_crew
REDIS_URL=redis://localhost:6379

# Context graph backend:
#   fallback = compliance subgraph built in Python, no extra infra (default)
#   age      = use the Apache AGE graph in Postgres (needs an AGE-enabled image
#              + a graph seeded via `python -m scripts.seed_graph`)
GRAPH_BACKEND=fallback

# Structural-embedding similarity backend (L4 #3):
#   fallback = cosine computed in Python over JSON embeddings, no extra infra (default)
#   pgvector = use pgvector's `<=>` operator in Postgres (needs the pgvector image —
#              L2Knowledge_graph/deploy/postgres-age.Dockerfile; one-time `down -v`)
VECTOR_BACKEND=fallback
